   "source": [
    "## Remove duplicate elements from a list using sets."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "2078a1ae-4d46-4313-b214-40d95e67861e",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Original List: [1, 2, 3, 2, 4, 1, 5, 3]\n",
      "List after removing duplicates: [1, 2, 3, 4, 5]\n"
     ]
    }
   ],
   "source": [
    "# Original list with duplicates\n",
    "numbers = [1, 2, 3, 2, 4, 1, 5, 3]\n",
    "\n",
    "# Removing duplicates using set\n",
    "unique_numbers = list(set(numbers))\n",
    "\n",
    "print(\"Original List:\", numbers)\n",
    "print(\"List after removing duplicates:\", unique_numbers)"
   ]
  },
